{
  "name": "rspack-repro",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "rimraf node_modules/.cache && npm-run-all build:*:* --sequential --print-name",
    "build:rspack:no-sharing": "cross-env RSPACK=1 CACHE_READ_WRITE_AND_NO_SHARING=1 rspack",
    "build:rspack:sharing": "cross-env RSPACK=1 CACHE_READ_ONLY_AND_SHARING=1 rspack",
    "build:webpack:no-sharing": "cross-env WEBPACK=1 CACHE_READ_WRITE_AND_NO_SHARING=1 webpack -c ./rspack.config.mjs",
    "build:webpack:sharing": "cross-env WEBPACK=1 CACHE_READ_ONLY_AND_SHARING=1 webpack -c ./rspack.config.mjs",
    "dev:rspack": "cross-env RSPACK=1 rspack dev",
    "dev:webpack": "cross-env WEBPACK=1 webpack serve -c ./rspack.config.mjs"
  },
  "dependencies": {
    "@rspack/cli": "^2.1.2",
    "@rspack/core": "^2.1.2",
    "@module-federation/runtime-tools": "^2.6.0",
    "html-webpack-plugin": "^5.6.7",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0",
    "lodash-es": "^4.18.1",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.2",
    "@rspack/dev-server": "^2.0.1",
    "cross-env": "^10.1.0",
    "npm-run-all2": "^8.0.4"
  },
  "packageManager": "pnpm@10.33.2"
}